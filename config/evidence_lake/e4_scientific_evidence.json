{
  "schema_version": "spacegate.scientific_evidence_contract.v1",
  "contract_version": "2026-07-19.e4-foundation.12",
  "compiler_version": "scientific_evidence_compiler_v12",
  "artifact_family": "scientific_evidence",
  "binding_statuses": [
    "accepted",
    "missing",
    "excluded",
    "ambiguous",
    "quarantined",
    "unresolved"
  ],
  "field_dispositions": [
    "domain",
    "identity",
    "lineage",
    "context",
    "exclude"
  ],
  "mapping_statuses": [
    "materialized",
    "declared_pending",
    "excluded"
  ],
  "identifier_claims": {
    "ctoi_alias": {"namespace": "ctoi_id", "claim_scope": "planet_candidate"},
    "epic_candname": {"namespace": "epic_candidate_id", "claim_scope": "planet_or_candidate"},
    "epic_hostname": {"namespace": "epic_host_id", "claim_scope": "host"},
    "epic_id": {"namespace": "epic_id", "claim_scope": "observation_target"},
    "gaia_dr2_id": {"namespace": "gaia_dr2_source_id", "claim_scope": "star"},
    "gaia_dr3_id": {"namespace": "gaia_dr3_source_id", "claim_scope": "star"},
    "hd_name": {"namespace": "hd_designation", "claim_scope": "star"},
    "hip_name": {"namespace": "hip_designation", "claim_scope": "star"},
    "hostname": {"namespace": "nasa_hostname", "claim_scope": "host"},
    "k2_name": {"namespace": "k2_planet_name", "claim_scope": "planet"},
    "kepid": {"namespace": "kepler_target_id", "claim_scope": "observation_target"},
    "kepler_name": {"namespace": "kepler_planet_name", "claim_scope": "planet"},
    "kepoi_name": {"namespace": "koi_id", "claim_scope": "planet_candidate"},
    "koi_name": {"namespace": "koi_id", "claim_scope": "planet_candidate"},
    "pl_letter": {"namespace": "planet_component_label", "claim_scope": "component_label"},
    "pl_name": {"namespace": "nasa_planet_name", "claim_scope": "planet_or_candidate"},
    "tce_delivname": {"namespace": "kepler_tce_delivery_id", "claim_scope": "observation_product"},
    "tce_plnt_num": {"namespace": "kepler_tce_signal_number", "claim_scope": "signal_component"},
    "tic_id": {"namespace": "tic_id", "claim_scope": "observation_target"},
    "tid": {"namespace": "tic_id", "claim_scope": "observation_target"},
    "toi": {"namespace": "toi_id", "claim_scope": "planet_candidate"},
    "toipfx": {"namespace": "toi_host_prefix", "claim_scope": "observation_target"}
  },
  "unit_normalizations": {
    "%": "percent",
    "AU": "au",
    "BJD": "BJD",
    "BKJD": "BKJD",
    "Earth Flux": "S_earth",
    "Earth Mass": "M_earth",
    "Earth Radius": "R_earth",
    "Earth flux": "S_earth",
    "Fearth": "S_earth",
    "Gyr": "Gyr",
    "Jupiter Mass": "M_jup",
    "Jupiter Radius": "R_jup",
    "K": "K",
    "Mearth": "M_earth",
    "Mjupiter": "M_jup",
    "Msun": "M_sun",
    "R_Earth": "R_earth",
    "R_Sun": "R_sun",
    "Rearth": "R_earth",
    "Rjupiter": "R_jup",
    "Rsun": "R_sun",
    "Searth": "S_earth",
    "Solar Radius": "R_sun",
    "Solar mass": "M_sun",
    "au": "au",
    "cm/s**2": "cm s-2",
    "day": "d",
    "days": "d",
    "deg": "deg",
    "degrees": "deg",
    "dex": "dex",
    "earth": "earth",
    "g/cm**3": "g cm-3",
    "hour": "h",
    "hours": "h",
    "hrs": "h",
    "km/s": "km s-1",
    "log(Lsun)": "dex(L_sun)",
    "log(Solar)": "dex(L_sun)",
    "log(cm/s**2)": "dex(cm s-2)",
    "log10(cm/s**2)": "dex(cm s-2)",
    "m/s": "m s-1",
    "mag": "mag",
    "mags": "mag",
    "mas": "mas",
    "mas/yr": "mas yr-1",
    "pc": "pc",
    "ppm": "ppm",
    "solar": "solar"
  },
  "domain_tables": [
    "identifier_claim_evidence",
    "stellar_parameter_sets",
    "stellar_parameter_evidence",
    "stellar_classification_evidence",
    "astrometry_distance_evidence",
    "photometry_extinction_evidence",
    "spectra_product_index",
    "variability_activity_rotation_evidence",
    "relation_claim_evidence",
    "orbital_solution_evidence",
    "cluster_evidence",
    "cluster_membership_evidence",
    "planet_parameter_sets",
    "planet_parameter_evidence",
    "planet_lifecycle_evidence",
    "transit_observation_evidence",
    "radial_velocity_evidence",
    "compact_object_evidence",
    "extended_object_evidence",
    "citations",
    "evidence_citations",
    "observation_product_lineage"
  ],
  "field_profiles": {
    "nasa_planet_archive": [
      {
        "pattern": "^(pl_name|pl_letter|hostname|hd_name|hip_name|tic_id|gaia_dr2_id|gaia_dr3_id|epic_candname|epic_hostname|k2_name)$",
        "disposition": "identity",
        "destination": "identifier_claim_evidence",
        "reason": "source-scoped object or observation-target identity"
      },
      {
        "pattern": "(^.*_(refname|reflink|solnid)$|^(rowupdate|releasedate|pl_pubdate|default_flag)$)",
        "disposition": "lineage",
        "destination": "source_records",
        "reason": "reference, solution, release, or preferred-row lineage"
      },
      {
        "pattern": "^(disposition|disp_refname)$",
        "disposition": "domain",
        "destination": "planet_lifecycle_evidence",
        "reason": "planet disposition evidence"
      },
      {
        "pattern": "^disc_.*$",
        "disposition": "context",
        "destination": "source_records",
        "reason": "discovery facility, publication, method, and date context"
      },
      {
        "pattern": "^pl_rvamp.*$",
        "disposition": "domain",
        "destination": "radial_velocity_evidence",
        "reason": "radial-velocity semi-amplitude observation"
      },
      {
        "pattern": "^pl_(tran.*|occ.*|imppar.*|ratdor.*|ratror.*|ttv.*)$",
        "disposition": "domain",
        "destination": "transit_observation_evidence",
        "reason": "transit, occultation, or timing observation"
      },
      {
        "pattern": "^pl_.*$",
        "disposition": "domain",
        "destination": "planet_parameter_evidence",
        "reason": "planet parameter-set evidence"
      },
      {
        "pattern": "^st_spectype$",
        "disposition": "domain",
        "destination": "stellar_classification_evidence",
        "reason": "host-star source spectral classification"
      },
      {
        "pattern": "^st_(rotp|vsin).*$",
        "disposition": "domain",
        "destination": "variability_activity_rotation_evidence",
        "reason": "host-star rotation period or projected rotation evidence"
      },
      {
        "pattern": "^st_radv.*$",
        "disposition": "domain",
        "destination": "astrometry_distance_evidence",
        "reason": "host-star systemic radial-velocity evidence"
      },
      {
        "pattern": "^st_.*$",
        "disposition": "domain",
        "destination": "stellar_parameter_evidence",
        "reason": "host-star parameter-set evidence"
      },
      {
        "pattern": "^sy_.*mag.*$",
        "disposition": "domain",
        "destination": "photometry_extinction_evidence",
        "reason": "system or host photometry"
      },
      {
        "pattern": "^(ra|dec|rastr|decstr|glat|glon|elat|elon|sy_(dist|plx|pm|pmra|pmdec|rv).*)$",
        "disposition": "domain",
        "destination": "astrometry_distance_evidence",
        "reason": "position, motion, velocity, parallax, or distance evidence"
      },
      {
        "pattern": "^(.*_flag|discoverymethod|soltype|k2_campaigns.*)$",
        "disposition": "context",
        "destination": "source_records",
        "reason": "discovery-method, detection-channel, and campaign context"
      },
      {
        "pattern": "^(x|y|z|htm20)$",
        "disposition": "exclude",
        "destination": "source_records",
        "reason": "archive spatial-index helper retained upstream but not scientific evidence"
      },
      {
        "pattern": "^sy_.*$",
        "disposition": "context",
        "destination": "source_records",
        "reason": "system context retained with the exact source record"
      },
      {
        "pattern": ".*",
        "disposition": "context",
        "destination": "source_records",
        "mapping_status": "declared_pending",
        "reason": "source-native ancillary context pending scientific-use review"
      }
    ],
    "nasa_toi": [
      {
        "pattern": "^(tid|toi|toipfx|ctoi_alias)$",
        "disposition": "identity",
        "destination": "identifier_claim_evidence",
        "reason": "TIC/TOI observation-target identity"
      },
      {
        "pattern": "^(tfopwg_disp|toi_created|rowupdate)$",
        "disposition": "domain",
        "destination": "planet_lifecycle_evidence",
        "reason": "TOI disposition and lifecycle timestamp"
      },
      {
        "pattern": "^pl_(tran.*|imppar.*|ror.*)$",
        "disposition": "domain",
        "destination": "transit_observation_evidence",
        "reason": "TOI transit observation"
      },
      {
        "pattern": "^pl_.*$",
        "disposition": "domain",
        "destination": "planet_parameter_evidence",
        "reason": "TOI planet-candidate parameter evidence"
      },
      {
        "pattern": "^st_tmag.*$",
        "disposition": "domain",
        "destination": "photometry_extinction_evidence",
        "reason": "TOI host TESS-band photometry"
      },
      {
        "pattern": "^(ra|dec)(err1|err2|str|symerr)?$|^st_(dist|pmra|pmdec).*$",
        "disposition": "domain",
        "destination": "astrometry_distance_evidence",
        "reason": "TOI host position, motion, or distance evidence"
      },
      {
        "pattern": "^st_.*$",
        "disposition": "domain",
        "destination": "stellar_parameter_evidence",
        "reason": "TOI host-star parameter evidence"
      },
      {
        "pattern": "^(release_date|sectors)$",
        "disposition": "context",
        "destination": "source_records",
        "reason": "TOI release and observing-sector context"
      },
      {
        "pattern": ".*",
        "disposition": "context",
        "destination": "source_records",
        "mapping_status": "declared_pending",
        "reason": "TOI ancillary context retained with the source record"
      }
    ],
    "nasa_koi": [
      {
        "pattern": "^(kepid|kepoi_name|kepler_name)$",
        "disposition": "identity",
        "destination": "identifier_claim_evidence",
        "reason": "Kepler target and candidate identity"
      },
      {
        "pattern": "^koi_(disposition|pdisposition|disp_prov|delivname)$",
        "disposition": "domain",
        "destination": "planet_lifecycle_evidence",
        "reason": "KOI disposition and delivery lineage"
      },
      {
        "pattern": "^koi_s(teff|logg|met|rad|mass|age|rho).*$",
        "disposition": "domain",
        "destination": "stellar_parameter_evidence",
        "reason": "KOI host-star parameter evidence"
      },
      {
        "pattern": "^koi_(kepmag|gmag|rmag|imag|zmag|jmag|hmag|kmag).*$",
        "disposition": "domain",
        "destination": "photometry_extinction_evidence",
        "reason": "KOI target photometry"
      },
      {
        "pattern": "^(ra|dec)(|_err|_str)$|^koi_(sra|sdec|g[lr]on).*$",
        "disposition": "domain",
        "destination": "astrometry_distance_evidence",
        "reason": "KOI target position"
      },
      {
        "pattern": "^koi_(period|time0bk|time0|impact|duration|ingress|depth|ror|dor|incl|teq|insol|model_snr|num_transits|tce).*$",
        "disposition": "domain",
        "destination": "transit_observation_evidence",
        "reason": "KOI transit or linked TCE evidence"
      },
      {
        "pattern": "^koi_datalink_.*$",
        "disposition": "lineage",
        "destination": "observation_product_lineage",
        "reason": "Kepler data-validation report and summary product locators"
      },
      {
        "pattern": "^koi_.*$",
        "disposition": "domain",
        "destination": "planet_parameter_evidence",
        "reason": "KOI candidate parameter evidence"
      },
      {
        "pattern": ".*",
        "disposition": "context",
        "destination": "source_records",
        "mapping_status": "declared_pending",
        "reason": "KOI ancillary context retained with the source record"
      }
    ],
    "nasa_tce": [
      {
        "pattern": "^(kepid|tce_plnt_num|tce_delivname)$",
        "disposition": "identity",
        "destination": "identifier_claim_evidence",
        "reason": "Kepler target, signal number, and delivery identity"
      },
      {
        "pattern": "^(ra|dec)$",
        "disposition": "domain",
        "destination": "astrometry_distance_evidence",
        "reason": "Kepler threshold-crossing-event sky position"
      },
      {
        "pattern": "^tce_datalink_.*$",
        "disposition": "lineage",
        "destination": "observation_product_lineage",
        "reason": "Kepler TCE data-validation report and summary product locators"
      },
      {
        "pattern": "^tce_.*$",
        "disposition": "domain",
        "destination": "transit_observation_evidence",
        "reason": "threshold-crossing event evidence"
      },
      {
        "pattern": "^(av_|boot_|tcet_|wst_).*$",
        "disposition": "domain",
        "destination": "transit_observation_evidence",
        "reason": "Kepler pipeline classification, bootstrap, and alternate-fit diagnostics"
      },
      {
        "pattern": "^rowupdate$",
        "disposition": "lineage",
        "destination": "source_records",
        "reason": "source update lineage"
      },
      {
        "pattern": ".*",
        "disposition": "context",
        "destination": "source_records",
        "mapping_status": "declared_pending",
        "reason": "TCE ancillary context retained with the source record"
      }
    ],
    "nasa_names": [
      {
        "pattern": ".*",
        "disposition": "identity",
        "destination": "identifier_claim_evidence",
        "reason": "official archive identifier crosswalk"
      }
    ]
  },
  "source_adapters": {
    "nasa_exoplanet_archive.planetary_systems": {
      "adapter_version": "nasa_scientific_evidence_v4",
      "tables": {
        "nasa_ps_reference_v2": {
          "logical_key_fields": ["pl_name", "pl_refname"],
          "object_scope": "planet",
          "field_profile": "nasa_planet_archive",
          "planet_parameter_set": {"kind": "reference_specific", "reference_field": "pl_refname"},
          "stellar_parameter_set": {"kind": "reference_specific_host", "reference_field": "st_refname"},
          "system_reference_field": "sy_refname",
          "signal_identifier_fields": ["pl_name"]
        },
        "nasa_pscomppars_v2": {
          "logical_key_fields": ["pl_name"],
          "object_scope": "planet",
          "field_profile": "nasa_planet_archive",
          "planet_parameter_set": {"kind": "archive_composite"},
          "stellar_parameter_set": {"kind": "archive_composite_host"},
          "signal_identifier_fields": ["pl_name"],
          "lifecycle_claims": [
            {
              "claim_role": "confirmed_archive_composite",
              "identifier_field": "pl_name",
              "implicit_disposition": "CONFIRMED",
              "reference_field": "disc_refname",
              "context_fields": [
                "disc_year",
                "disc_pubdate",
                "disc_facility",
                "disc_telescope",
                "disc_instrument",
                "disc_locale"
              ]
            }
          ]
        },
        "nasa_stellarhosts_v2": {
          "logical_key_fields": ["hostname", "st_refname"],
          "object_scope": "host",
          "field_profile": "nasa_planet_archive",
          "stellar_parameter_set": {"kind": "reference_specific_host", "reference_field": "st_refname"},
          "system_reference_field": "sy_refname"
        },
        "nasa_toi_full_v2": {
          "logical_key_fields": ["toi"],
          "object_scope": "observation_target",
          "field_profile": "nasa_toi",
          "planet_parameter_set": {"kind": "toi_candidate"},
          "stellar_parameter_set": {"kind": "toi_host"},
          "signal_identifier_fields": ["toi"],
          "lifecycle_claims": [
            {
              "claim_role": "toi_tfopwg_disposition",
              "identifier_field": "toi",
              "disposition_field": "tfopwg_disp",
              "effective_field": "rowupdate",
              "context_fields": ["toi_created"]
            }
          ]
        },
        "nasa_k2_planets_candidates_v2": {
          "logical_key_fields": ["pl_name", "pl_refname"],
          "object_scope": "planet_or_candidate",
          "field_profile": "nasa_planet_archive",
          "planet_parameter_set": {"kind": "reference_specific_candidate", "reference_field": "pl_refname"},
          "stellar_parameter_set": {"kind": "reference_specific_host", "reference_field": "st_refname"},
          "system_reference_field": "sy_refname",
          "signal_identifier_fields": ["pl_name"],
          "lifecycle_claims": [
            {
              "claim_role": "k2_archive_disposition",
              "identifier_field": "pl_name",
              "disposition_field": "disposition",
              "reference_field": "disp_refname",
              "effective_field": "rowupdate",
              "context_fields": [
                "disc_year",
                "disc_pubdate",
                "disc_facility",
                "disc_telescope",
                "disc_instrument",
                "disc_locale"
              ]
            }
          ]
        },
        "nasa_kepler_names_v2": {
          "logical_key_fields": ["kepid", "pl_name", "koi_name", "kepler_name"],
          "object_scope": "identifier_crosswalk",
          "field_profile": "nasa_names"
        },
        "nasa_k2_names_v2": {
          "logical_key_fields": ["epic_id", "pl_name", "k2_name"],
          "object_scope": "identifier_crosswalk",
          "field_profile": "nasa_names"
        },
        "nasa_kepler_dr25_koi_v2": {
          "logical_key_fields": ["kepoi_name"],
          "object_scope": "observation_target",
          "field_profile": "nasa_koi",
          "planet_parameter_set": {"kind": "kepler_pipeline_candidate"},
          "stellar_parameter_set": {"kind": "kepler_pipeline_host"},
          "signal_identifier_fields": ["kepoi_name"],
          "lifecycle_claims": [
            {
              "claim_role": "koi_archive_disposition",
              "identifier_field": "kepoi_name",
              "disposition_field": "koi_disposition",
              "reference_field": "koi_disp_prov",
              "context_fields": ["koi_delivname"]
            },
            {
              "claim_role": "koi_pipeline_disposition",
              "identifier_field": "kepoi_name",
              "disposition_field": "koi_pdisposition",
              "reference_field": "koi_disp_prov",
              "context_fields": ["koi_delivname"]
            }
          ]
        },
        "nasa_kepler_dr25_supplemental_koi_v2": {
          "logical_key_fields": ["kepoi_name"],
          "object_scope": "observation_target",
          "field_profile": "nasa_koi",
          "planet_parameter_set": {"kind": "kepler_pipeline_candidate"},
          "stellar_parameter_set": {"kind": "kepler_pipeline_host"},
          "signal_identifier_fields": ["kepoi_name"],
          "lifecycle_claims": [
            {
              "claim_role": "koi_archive_disposition",
              "identifier_field": "kepoi_name",
              "disposition_field": "koi_disposition",
              "reference_field": "koi_disp_prov",
              "context_fields": ["koi_delivname"]
            },
            {
              "claim_role": "koi_pipeline_disposition",
              "identifier_field": "kepoi_name",
              "disposition_field": "koi_pdisposition",
              "reference_field": "koi_disp_prov",
              "context_fields": ["koi_delivname"]
            }
          ]
        },
        "nasa_kepler_cumulative_koi_v2": {
          "logical_key_fields": ["kepoi_name"],
          "object_scope": "observation_target",
          "field_profile": "nasa_koi",
          "planet_parameter_set": {"kind": "kepler_pipeline_candidate"},
          "stellar_parameter_set": {"kind": "kepler_pipeline_host"},
          "signal_identifier_fields": ["kepoi_name"],
          "lifecycle_claims": [
            {
              "claim_role": "koi_archive_disposition",
              "identifier_field": "kepoi_name",
              "disposition_field": "koi_disposition",
              "reference_field": "koi_disp_prov",
              "context_fields": ["koi_delivname"]
            },
            {
              "claim_role": "koi_pipeline_disposition",
              "identifier_field": "kepoi_name",
              "disposition_field": "koi_pdisposition",
              "reference_field": "koi_disp_prov",
              "context_fields": ["koi_delivname"]
            }
          ]
        },
        "nasa_kepler_dr25_tce_v2": {
          "logical_key_fields": ["kepid", "tce_plnt_num"],
          "object_scope": "observation_target",
          "field_profile": "nasa_tce",
          "signal_identifier_fields": ["kepid", "tce_plnt_num", "tce_delivname"]
        },
        "nasa_transit_detection_reference_v2": {
          "logical_key_fields": ["pl_name", "pl_refname"],
          "object_scope": "planet",
          "field_profile": "nasa_planet_archive",
          "planet_parameter_set": {"kind": "transit_reference_specific", "reference_field": "pl_refname"},
          "stellar_parameter_set": {"kind": "transit_reference_host", "reference_field": "st_refname"},
          "system_reference_field": "sy_refname",
          "signal_identifier_fields": ["pl_name"]
        }
      }
    }
  }
}
