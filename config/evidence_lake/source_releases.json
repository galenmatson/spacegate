    "multiplicity": "component relations, system membership, and orbit evidence",
    "planet_inventory": "confirmed/candidate/negative planet evidence and lifecycle",
    "planet_parameters": "planet and transit/RV parameter sets",
    "cluster": "cluster identity, physical context, and membership claims",
    "extended_objects": "non-stellar object identity, geometry, and distance",
    "observation_products": "spectra, light curves, atmosphere spectra, images, and product metadata"
  },
