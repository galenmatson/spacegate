    "buffer_radius_ly": 1250.0,
    "selection_policy": "buffered_parallax_plus_posterior_overlap_v1",
    "candidate_rules": [
      "include sources whose accepted distance interval overlaps the 1000 ly public boundary",
      "include the deterministic 1250 ly acquisition buffer",
      "retain boundary exclusions and reasons",
      "do not use a distance estimate as an identity replacement"
    ],
    "status": "policy_defined_measurement_pending"
  },
  "storage_budgets": {
    "internal_min_free_before_acquisition_gib": 300,
