    "reports_gib": 20,
    "bulk_observation_cache_gib": 500,
    "bulk_research_documents_gib": 350,
    "policy": "Budgets are gates, not reservations; stop before a write that would breach the applicable free-space floor."
  },
  "field_policy": {
    "allowed_dispositions": ["preserve", "normalize", "index_only", "omit"],
    "default_disposition": "preserve",
    "schema_drift": "fail_until_reviewed",
    "new_field_policy": "preserve_in_raw_and_typed_then_require_explicit_evidence_mapping_or_omit_reason",
    "omit_requires_reason": true
  },
  "authority_domains": {
    "inventory": "physical object existence and source release membership",
